DATABASE_URL=sqlite:///soulsync.db
GOOGLE_API_KEY=
GEMINI_MODEL_ID=gemini-2.0-flash

# ============================================================
# NIMS - Neurodivergent Interaction Modelling System
# ============================================================

# Enables the NIMS extension foundation.
NIMS_ENABLED=true

# If true, Your Voice should only use models approved by NIMS.
NIMS_REQUIRE_APPROVED_MODEL=true

# Shows NIMS diagnostic metadata in development/research UI.
NIMS_DEBUG_PANEL=false

# Default candidate model values used when no explicit candidate is selected.
NIMS_DEFAULT_PROVIDER=gemini
NIMS_DEFAULT_MODEL_ID=gemini-default

# NIMS deterministic approval thresholds.
NIMS_MIN_APPROVAL_SCORE=0.82
NIMS_MAX_SAFETY_FAILURES=0
NIMS_MAX_TOPIC_FAILURES=1
NIMS_MAX_LITERALNESS_FAILURES=1
